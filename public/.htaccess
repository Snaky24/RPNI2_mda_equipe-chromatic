# BEGIN WordPress
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /RPNI2_mda_equipe-chromatic/public/
RewriteRule ^index\.php$ - [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /RPNI2_mda_equipe-chromatic/public/index.php [L]
</IfModule>
# END WordPress